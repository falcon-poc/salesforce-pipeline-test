# Keep only non-namespaced custom fields
!CustomField/*.*__c
!CustomObject/*__c
!CustomObject/*__mdt
!CustomObject/*__e
CustomField/*.*__*__c

# Managed package objects and their fields
CustomObject/*__dll
CustomObject/*__dlm
CustomObject/*__hd
CustomField/*__dll.*
CustomField/*__dlm.*
CustomField/*__hd.*

# Namespaced permission sets and groups
PermissionSet/*__*
PermissionSetGroup/force__*

# System-generated Apex classes
ApexClass/ChangePasswordController
ApexClass/ChangePasswordControllerTest
ApexClass/CommunitiesLandingController
ApexClass/CommunitiesLandingControllerTest
ApexClass/CommunitiesLoginController
ApexClass/CommunitiesLoginControllerTest
ApexClass/CommunitiesSelfRegConfirmController
ApexClass/CommunitiesSelfRegConfirmControllerTest
ApexClass/CommunitiesSelfRegController
ApexClass/CommunitiesSelfRegControllerTest
ApexClass/FieldAPINameValidatorMock
ApexClass/ForgotPasswordController
ApexClass/ForgotPasswordControllerTest
ApexClass/IProgramPublishValidator
ApexClass/MicrobatchSelfRegController
ApexClass/MicrobatchSelfRegControllerTest
ApexClass/MyProfilePageController
ApexClass/MyProfilePageControllerTest
ApexClass/ProgramPublishService
ApexClass/ProgramPublishServiceTest
ApexClass/SiteLoginController
ApexClass/SiteLoginControllerTest
ApexClass/SiteRegisterController
ApexClass/SiteRegisterControllerTest

# Specific fields we don't own
CustomField/AccountContactRelation.Relationship_Strength__c
CustomField/In_App_Checklist_Settings__c.ProfileKey__c
CustomField/In_App_Checklist_Settings__c.Sales_Cloud_In_App_Page__c
CustomField/Invoice_Data__c.Field_1__c
CustomField/Opportunity.Budget_Confirmed__c
CustomField/Opportunity.Discovery_Completed__c
CustomField/Opportunity.Loss_Reason__c
CustomField/Opportunity.ROI_Analysis_Completed__c

# Specific permission sets we don't own
PermissionSet/Program_Config_Admin
PermissionSet/Sales_User
